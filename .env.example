# ============================================================================
# mail-server — environment configuration
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================================

# --- General ---------------------------------------------------------------
# Primary hostname of the mail server itself (the FQDN clients connect to,
# and the HELO/EHLO name Postfix announces). Must have an A record + PTR.
MAIL_HOSTNAME=mail.example.com

# Comma-separated hostnames the web UI / API is served on.
WEB_HOSTNAME=admin.example.com

# Deployment environment: development | production
ENVIRONMENT=production

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mailserver
POSTGRES_USER=mailserver
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=changeme-strong-db-password

# Read-only role used by Postfix/Dovecot for SQL lookups (least privilege).
POSTGRES_MAIL_USER=mail_lookup
POSTGRES_MAIL_PASSWORD=changeme-lookup-password

# --- Redis -----------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme-redis-password

# --- Backend / JWT ---------------------------------------------------------
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=changeme-64-char-hex-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Key used to encrypt DKIM private keys at rest (Fernet key, 32 url-safe b64).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_ENCRYPTION_KEY=changeme-fernet-key

# First superadmin, created on first boot if no users exist.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme-strong-admin-password

# --- Cloudflare DNS --------------------------------------------------------
# Scoped API token with Zone:DNS:Edit on the relevant zones.
CLOUDFLARE_API_TOKEN=changeme-cloudflare-token
# Optional: restrict automation to a single account.
CLOUDFLARE_ACCOUNT_ID=

# --- TLS / ACME ------------------------------------------------------------
# Email Let's Encrypt uses for expiry notices.
ACME_EMAIL=admin@example.com
# Set to 1 to use the Let's Encrypt staging CA (avoids rate limits while testing).
ACME_STAGING=0

# --- Spam filtering (Rspamd) -----------------------------------------------
# Password for the Rspamd controller web UI (:11334). Leave blank to disable
# the web login (the milter still works). Generate: openssl rand -base64 24
RSPAMD_PASSWORD=

# --- Outbound SMTP relay (optional smarthost) ------------------------------
# Leave RELAYHOST blank to send mail directly on port 25 (needs port 25 open +
# PTR). Set it to relay outbound through a provider instead — required when
# port 25 is blocked (home/NAT, or clouds that block 25). Brackets skip MX
# lookup. Examples: [smtp-relay.brevo.com]:587, [email-smtp.us-east-1.amazonaws.com]:587
RELAYHOST=
RELAY_USERNAME=
RELAY_PASSWORD=

# --- Mail defaults ---------------------------------------------------------
# Default per-mailbox quota in MB for newly created mailboxes.
DEFAULT_MAILBOX_QUOTA_MB=2048
# Maildir root inside the mail containers (mounted volume).
MAILDIR_ROOT=/maildata

# --- Rate limiting ---------------------------------------------------------
# Authenticated API requests per minute, per principal.
RATE_LIMIT_API_PER_MINUTE=120
# Failed-login attempts before temporary lockout.
RATE_LIMIT_LOGIN_ATTEMPTS=5

# --- CORS ------------------------------------------------------------------
# Comma-separated allowed origins for the browser SPA.
CORS_ORIGINS=https://admin.example.com
