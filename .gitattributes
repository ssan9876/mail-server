# Normalize line endings. Shell scripts and container configs MUST be LF so
# their shebangs/parsing work inside the Linux images regardless of the OS the
# repo was cloned/edited on.
* text=auto eol=lf

*.sh        text eol=lf
*.cf        text eol=lf
*.inc       text eol=lf
*.conf      text eol=lf
*.template  text eol=lf
*.ext       text eol=lf
*.mako      text eol=lf
Dockerfile  text eol=lf
Makefile    text eol=lf
